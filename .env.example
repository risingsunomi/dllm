# Required for real inference.
DLLM_MODEL_NAME=Qwen/Qwen2.5-0.5B-Instruct

# Node identity and device.
DLLM_NODE_NAME=node-a
DLLM_DEVICE=cpu

# server = HTTP shard server only.
# worker = TCP inference worker only.
# both = local TCP worker plus HTTP shard server.
DLLM_ROLE=server

# HTTP server bind address.
DLLM_HOST=0.0.0.0
DLLM_PORT=8000

# TCP worker bind address.
DLLM_PEER_HOST=0.0.0.0
DLLM_PEER_PORT=8765

# Comma-separated peers for the HTTP server:
#   node-b@192.168.0.5:8765,node-c@192.168.0.6:8765
DLLM_PEERS=

# Server nodes must keep this enabled because they run the first shard.
DLLM_LOAD_LOCAL=true

# LAN peer discovery can be combined with explicit DLLM_PEERS.
DLLM_PEER_DISCOVERY=true
DLLM_DISCOVERY_PORT=8764
DLLM_DISCOVERY_TIMEOUT=1

# Generation defaults.
DLLM_MAX_NEW_TOKENS=128
DLLM_TEMPERATURE=0
DLLM_TOP_P=1
DLLM_TOP_K=0
DLLM_REPETITION_PENALTY=1
DLLM_CONTEXT_LENGTH=0

# Model loading behavior.
DLLM_OFFLINE=false
DLLM_DTYPE=auto
DLLM_TRUST_REMOTE_CODE=false

# Large/MoE model loading. Leave blank for normal single-device loading.
# Examples:
#   DLLM_DEVICE_MAP=auto
#   DLLM_MAX_MEMORY=0=20GiB,cpu=80GiB
DLLM_DEVICE_MAP=
DLLM_MAX_MEMORY=
DLLM_OFFLOAD_FOLDER=
DLLM_ATTENTION_IMPLEMENTATION=

# For multimodal/VLM repos, load only the language stack when config/weights
# expose it separately. This ignores vision tower weights.
DLLM_LANGUAGE_ONLY=true
DLLM_LANGUAGE_WEIGHT_PREFIX=auto

# Optional extra checkpoint key mapping for nonstandard safetensor keys.
# The source side is a Python regular expression pattern.
# Examples:
#   DLLM_WEIGHT_KEY_MAPPING=auto
#   DLLM_WEIGHT_KEY_MAPPING=^layers\.=model.layers.,^head\.weight$=lm_head.weight
DLLM_WEIGHT_KEY_MAPPING=
